# Copy this file to ops/debug-switch-fabric.yaml and fill in local switch details.
# ops/debug-switch-fabric.yaml is ignored by Git.
#
# Password auth uses sshpass. This example is safe to commit because it contains
# placeholders only; the real ops/debug-switch-fabric.yaml is ignored by Git.

# Cluster-specific worker SSH settings. Worker node IPs are discovered from
# Kubernetes node InternalIP, but the login user/key/port/options belong here.
worker_ssh:
  user: root
  port: 22
  password: "<worker-password>"
  options: "-o BatchMode=yes -o ConnectTimeout=10"

# Used only for generated switch-<switch>-<port>-vlan0-L2.yaml fix proposals.
# SriovNetwork vlan: 0 sends untagged frames, so this is the switch-side
# access/native VLAN that should carry that L2 service.
switch_defaults:
  bridge_domain: br_default
  native_vlan: 1
  # Optional. When true, generated switch-<switch>-<port>-L3.yaml files include
  # gateway IP addresses computed from the pod IP block:
  #   gateway = network(pod_ip/l3_prefix) + l3_gateway_index
  # This is intended for nv-ipam CIDRPool designs with routed switch ports.
  l3_gateways: false
  l3_prefix: 27
  l3_gateway_index: 1
  # Optional. Set only if the routed server ports belong to a VRF.
  l3_vrf: red

switches:
  - name: leaf1
    host: 10.0.0.11
    user: cumulus
    port: 22
    password: "<switch-password>"
    # Optional. If omitted, debug-switch-fabric.sh tries to match ports from LLDP.
    server_ports: [swp13s0]

  - name: leaf2
    host: 10.0.0.12
    user: cumulus
    port: 22
    password: "<switch-password>"
    server_ports: [swp16s0]
